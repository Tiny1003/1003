#!/bin/bash

# =================================================================
# OS Class Project: Ubuntu Client Auditor
# 操作系统课程实验：Ubuntu 客户端远程审计工具
# =================================================================

# Configuration / 基础配置
SERVER_IP="192.168.x.x"  # 请务必在此处填入你的 Oracle Linux 服务器 IP
MOUNT_POINT="/mnt/remote_verify"

# ---------------------------------------------------------
# Feature 1: Initialize Environment
# 功能 1：自动化初始化环境
# ---------------------------------------------------------
init_env() {
    echo "Starting environment initialization..."
    echo "开始初始化环境..."
    
    # Update and install necessary tools
    # 更新并安装必要的工具
    sudo apt update
    sudo apt install -y cifs-utils curl
    
    echo "Environment is ready. cifs-utils and curl are installed."
    echo "环境准备完毕。cifs-utils 和 curl 已安装。"
}

# ---------------------------------------------------------
# Feature 2: Remote Resource Monitor (Hidden Condition 2)
# 功能 2：远程资源压力监控（隐形条件 2）
# ---------------------------------------------------------
check_web_health() {
    echo "Checking remote web server health..."
    echo "正在检查远程网页服务器健康状态..."
    
    # Get HTTP status code
    # 获取 HTTP 状态码
    HTTP_CODE=$(curl -s -o /dev/null -w "%{http_code}" http://$SERVER_IP/index.html)
    
    if [ "$HTTP_CODE" == "200" ]; then
        echo "Status: [OK] Web server responds normally (200)."
        echo "状态：[正常] 网页服务器响应正常 (200)。"
    else
        echo "Warning: [ALERT] Server is down or under pressure! Code: $HTTP_CODE"
        echo "警告：[报警] 服务器宕机或压力过大！错误码：$HTTP_CODE"
    fi
}

# ---------------------------------------------------------
# Feature 3: Remote Security Audit (Hidden Condition 1)
# 功能 3：远程安全权限审计（隐形条件 1）
# ---------------------------------------------------------
check_security() {
    echo "Auditing remote file permissions..."
    echo "正在审计远程文件权限..."
    
    # Create mount point
    # 创建挂载点
    if [ ! -d "$MOUNT_POINT" ]; then
        sudo mkdir -p $MOUNT_POINT
    fi
    
    # Mount the server's share
    # 挂载服务器的共享目录
    sudo mount -t cifs //$SERVER_IP/MyShare $MOUNT_POINT -o username=student,password=123,vers=3.0 2>/dev/null
    
    # Check if a specific file has 777 permission
    # 检查特定文件是否为 777 权限
    # Assume we check the directory itself if no file exists
    REMOTE_PERM=$(stat -c "%a" $MOUNT_POINT 2>/dev/null)
    
    if [ "$REMOTE_PERM" == "777" ]; then
        echo "Warning: [ALERT] Remote directory has unsafe 777 permission!"
        echo "警告：[报警] 远程目录存在不安全的 777 权限！"
    else
        echo "Status: [OK] Remote security is normal ($REMOTE_PERM)."
        echo "状态：[正常] 远程安全状态正常 ($REMOTE_PERM)。"
    fi
    
    # Unmount to keep system clean
    # 卸载以保持系统整洁
    sudo umount $MOUNT_POINT
}

# ---------------------------------------------------------
# Feature 4: Verify File Sharing
# 功能 4：验证文件共享互通
# ---------------------------------------------------------
verify_files() {
    echo "Connecting to remote file system..."
    echo "正在连接远程文件系统..."
    
    sudo mkdir -p $MOUNT_POINT
    sudo mount -t cifs //$SERVER_IP/MyShare $MOUNT_POINT -o username=student,password=123,vers=3.0
    
    echo "Connected successfully. Files in server:"
    echo "连接成功。服务器中的文件列表："
    ls -l $MOUNT_POINT
    
    sudo umount $MOUNT_POINT
}

# ---------------------------------------------------------
# Main Menu
# 主菜单
# ---------------------------------------------------------
while true
do
    echo ""
    echo "--- Ubuntu Client Auditor ---"
    echo "1. Initialize Environment (初始化网络环境)"
    echo "2. Check Web Server (网页服务存活检测)"
    echo "3. Remote Security Audit (远程权限安全审计)"
    echo "4. View Remote Files (查看远程共享文件)"
    echo "5. Exit (退出)"
    read -p "Select option [1-5]: " choice

    if [ "$choice" == "1" ]; then
        init_env
    elif [ "$choice" == "2" ]; then
        check_web_health
    elif [ "$choice" == "3" ]; then
        check_security
    elif [ "$choice" == "4" ]; then
        verify_files
    elif [ "$choice" == "5" ]; then
        echo "Exiting..."
        exit 0
    else
        echo "Invalid choice."
    fi
done
